          }
        ]
      ]
    },
    "Create Live Session": {
      "main": [
        [
          {
            "node": "Get Live URLs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Live URLs": {
      "main": [
        [
          {
            "node": "Format Session Details",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Session Details": {
      "main": [
        [
          {
            "node": "Save QR Pending State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save QR Pending State": {
      "main": [
        [
          {
            "node": "Format Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
