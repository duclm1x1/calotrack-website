          }
        ],
        [
          {
            "node": "Create Browserbase Context",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Browserbase Context": {
      "main": [
        [
          {
            "node": "Normalize Context",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize Context": {
      "main": [
        [
          {
