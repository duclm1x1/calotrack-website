              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"source\":\"n8n_token_keeper\"}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "force_refresh",
      "name": "Force Refresh Via Broker",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        -320
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.healthUrl }}",
