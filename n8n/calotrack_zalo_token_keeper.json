          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"access_token\":\"{{$json.accessToken}}\",\"refresh_token\":\"{{$json.refreshToken}}\",\"browserbase_context_id\":\"{{$json.browserbaseContextId}}\",\"last_reauth_status\":\"ok\",\"last_reauth_error\":\"\"}",
        "options": {
          "response": {
