    {
      "parameters": {
        "jsCode": "function normalizeBaseUrl(value) {\n  return String(value || '').trim().replace(/\\/+$/, '');\n}\n\nconst siteUrl = normalizeBaseUrl('https://calotrack-website.vercel.app');\nconst browserbaseRegion = String('ap-southeast-1').trim() || 'ap-southeast-1';\nconst explorerUrl = 'https://developers.zalo.me/tools/explorer/1450975846052622442';\n\nreturn [{\n  json: {\n    siteUrl,\n    explorerUrl,\n    healthUrl: `${siteUrl}/api/zalo-oa-health`,\n    refreshUrl: `${siteUrl}/api/zalo-oa-force-refresh`,\n    bootstrapUrl: `${siteUrl}/api/zalo-oa-bootstrap`,\n    brokerStateUrl: `${siteUrl}/api/zalo-oa-browserbase-state`,\n    browserbaseApiBase: 'https://api.browserbase.com/v1',\n    browserbaseApiKey: String('').trim(),\n    browserbaseProjectId: String('').trim(),\n    browserbaseRegion,\n    internalKey: String('').trim(),\n  },\n}];"
      },
      "id": "prepare_ops_context",
      "name": "Prepare Ops Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        -20
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.healthUrl }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-calotrack-internal-key",
              "value": "={{ $json.internalKey }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get_broker_health",
      "name": "Get Broker Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        520,
        -20
      ]
    },
    {
      "parameters": {
        "jsCode": "const base = $('Prepare Ops Context').first().json || {};\nconst source = $input.first().json || {};\nconst payload = source.data && typeof source.data === 'object' ? source.data : source;\nconst tokenStatus = String(payload.tokenStatus || payload.token_status || '').trim();\nconst hasAccessToken = payload.hasAccessToken !== false;\nconst hasRefreshToken = payload.hasRefreshToken !== false;\nconst browserbaseContextId = String(payload.browserbaseContextId || payload.browserbase_context_id || '').trim();\nconst needsRefresh = !hasAccessToken || !hasRefreshToken || ['expired', 'expiring_soon', 'refresh_failed'].includes(tokenStatus);\nconst needsReauth = ['reauthorization_required', 'bootstrap_required'].includes(tokenStatus);\n\nreturn [{\n  json: {\n    ...base,\n    health: payload,\n    tokenStatus,\n    hasAccessToken,\n    hasRefreshToken,\n    browserbaseContextId,\n    browserbaseReady: Boolean(browserbaseContextId),\n    needsRefresh,\n    needsReauth,\n    needsAction: needsRefresh || needsReauth,\n  },\n}];"
      },
      "id": "evaluate_health",
      "name": "Evaluate Health",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        780,
        -20
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "needs-action",
              "leftValue": "={{ $json.needsAction === true }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "needs_action",
      "name": "Needs Action?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1040,
        -20
      ]
    },
    {
      "parameters": {
        "jsCode": "const health = $('Evaluate Health').first().json || {};\nreturn [{\n  json: {\n    ok: true,\n    action: 'noop',\n    token_status: health.tokenStatus || 'healthy',\n    summary: 'Zalo OA token is healthy. No refresh or reauthorization needed.',\n  },\n}];"
      },
      "id": "format_noop",
      "name": "Format Noop Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        140
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "needs-reauth",
              "leftValue": "={{ $json.needsReauth === true }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "needs_reauth",
      "name": "Needs Reauth?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1300,
        -200
      ]
    },
