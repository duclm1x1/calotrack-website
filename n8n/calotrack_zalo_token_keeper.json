      "id": "verify_health_after_refresh",
      "name": "Verify Health After Refresh",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1820,
        -320
      ]
    },
    {
      "parameters": {
        "jsCode": "const source = $input.first().json || {};\nconst payload = source.data && typeof source.data === 'object' ? source.data : source;\nreturn [{\n  json: {\n    tokenStatus: String(payload.tokenStatus || payload.token_status || '').trim(),\n    browserbaseReady: Boolean(payload.browserbaseReady || payload.browserbase_ready || payload.browserbaseContextId || payload.browserbase_context_id),\n    browserbaseContextId: String(payload.browserbaseContextId || payload.browserbase_context_id || '').trim(),\n    data: payload,\n  },\n}];"
      },
      "id": "evaluate_refresh_result",
      "name": "Evaluate Refresh Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        -420
      ]
    },
    {
      "parameters": {
        "options": {},
        "conditions": {
          "options": {
            "version": 1,
            "typeValidation": "strict",
            "leftValue": "",
            "caseSensitive": true
          },
          "conditions": [
            {
              "operator": {
                "operation": "equals",
                "type": "boolean"
              },
              "rightValue": true,
              "id": "refresh-restored-health",
              "leftValue": "={{ ['healthy', 'expiring_soon'].includes(String($json.tokenStatus || '').trim()) }}"
            }
          ],
          "combinator": "and"
        }
      },
      "id": "refresh_restored_health",
      "name": "Refresh Restored Health?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2340,
        -420
      ]
    },
    {
      "parameters": {
        "jsCode": "const source = $input.first().json || {};\nconst payload = source.data && typeof source.data === 'object' ? source.data : source;\nreturn [{\n  json: {\n    ok: ['healthy', 'expiring_soon'].includes(String(payload.tokenStatus || payload.token_status || '').trim()),\n    action: 'refresh',\n    token_status: payload.tokenStatus || payload.token_status || 'unknown',\n    summary: ['healthy', 'expiring_soon'].includes(String(payload.tokenStatus || payload.token_status || '').trim())\n      ? 'Broker refresh completed successfully.'\n      : 'Broker refresh did not restore a healthy token state.',\n    data: payload,\n  },\n}];"
      },
      "id": "format_refresh_outcome",
      "name": "Format Refresh Outcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        -320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "has-browserbase-context",
              "leftValue": "={{ $json.browserbaseReady === true }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "has_browserbase_context",
      "name": "Has Browserbase Context?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1560,
        80
      ]
    },
    {
      "parameters": {
        "resource": "agent",
        "operation": "execute",
        "url": "={{ $json.explorerUrl }}",
        "instruction": "Open the page and make sure the selected application is Calo Track Nutrition Coach and the token type is OA Access Token. Read the full values from the Access token and Refresh token fields. Return only strict JSON with keys accessToken and refreshToken. Do not mask, shorten, or explain anything.",
        "driverModel": "google/gemini-2.5-flash",
        "mode": "dom",
        "modelDom": "google/gemini-2.5-flash",
        "options": {
          "maxSteps": 25,
          "systemPrompt": "You are extracting Zalo OA token values for a production token broker. Return exact token strings only in strict JSON."
        },
        "browserOptions": {
          "advancedStealth": true,
          "blockAds": true,
          "logSession": true,
          "recordSession": true,
          "solveCaptchas": false,
          "viewportWidth": 1288,
          "viewportHeight": 711
        },
        "sessionOptions": {
          "contextId": "={{ $json.browserbaseContextId }}",
          "keepAlive": false,
          "persistContext": true,
          "region": "ap-southeast-1",
          "timeout": 300,
          "proxies": true
        }
      },
      "id": "browserbase_scrape_tokens",
      "name": "Browserbase Scrape Tokens",
      "type": "n8n-nodes-browserbase.browserbase",
      "typeVersion": 2,
      "position": [
        1820,
        -20
      ],
      "credentials": {
        "browserbaseApi": {
          "name": "Browserbase API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const base = $('Evaluate Health').first().json || {};\nconst result = $input.first().json || {};\nconst rawMessage = String(result.message || result.output || '').trim();\nconst codeFenceMatch = rawMessage.match(/```json\\s*([\\s\\S]*?)```/i);\nconst candidate = (codeFenceMatch ? codeFenceMatch[1] : rawMessage).trim();\nlet parsed = {};\ntry {\n  parsed = JSON.parse(candidate);\n} catch {\n  const accessMatch = candidate.match(/\\\"?accessToken\\\"?\\s*[:=]\\s*\\\"([^\\\"]+)\\\"/i) || candidate.match(/access[_\\s-]?token\\s*[:=]\\s*([A-Za-z0-9_\\-.]+)/i);\n  const refreshMatch = candidate.match(/\\\"?refreshToken\\\"?\\s*[:=]\\s*\\\"([^\\\"]+)\\\"/i) || candidate.match(/refresh[_\\s-]?token\\s*[:=]\\s*([A-Za-z0-9_\\-.]+)/i);\n  parsed = {\n    accessToken: accessMatch?.[1] || '',\n    refreshToken: refreshMatch?.[1] || '',\n  };\n}\n\nconst accessToken = String(parsed.accessToken || parsed.access_token || '').trim();\nconst refreshToken = String(parsed.refreshToken || parsed.refresh_token || '').trim();\nif (!accessToken || !refreshToken) {\n  throw new Error('browserbase_scrape_failed');\n}\n\nreturn [{\n  json: {\n    ...base,\n    accessToken,\n    refreshToken,\n  },\n}];"
      },
      "id": "parse_scraped_tokens",
      "name": "Parse Scraped Tokens",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        -20
      ]
    },
