    {
      "parameters": {
        "jsCode": "const source = $input.first().json || {};\nconst payload = source.data && typeof source.data === 'object' ? source.data : source;\nreturn [{\n  json: {\n    ok: ['healthy', 'expiring_soon'].includes(String(payload.tokenStatus || payload.token_status || '').trim()),\n    action: 'reauth',\n    token_status: payload.tokenStatus || payload.token_status || 'unknown',\n    summary: ['healthy', 'expiring_soon'].includes(String(payload.tokenStatus || payload.token_status || '').trim())\n      ? 'Browserbase reauthorization succeeded and broker is healthy again.'\n      : 'Browserbase reauthorization ran but broker is still not healthy.',\n    data: payload,\n  },\n}];"
      },
      "id": "format_reauth_outcome",
      "name": "Format Reauth Outcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2860,
        -20
      ]
    },
    {
      "parameters": {
        "jsCode": "const base = $('Evaluate Health').first().json || {};\nreturn [{\n  json: {\n    ok: false,\n    action: 'manual_qr_required',\n    token_status: base.tokenStatus || 'reauthorization_required',\n    summary: 'Browserbase context is missing. Run CaloTrack - Zalo Browserbase QR Bootstrap, scan the QR in Live View, then rerun this workflow manually.',\n  },\n}];"
      },
      "id": "format_qr_required",
      "name": "Format QR Required",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1820,
        220
      ]
    }
  ],
